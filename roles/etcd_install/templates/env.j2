{% set endpoints = [] %}
{% for host in groups['etcd'] %}
{% set name = host.split('.')[0] %}
{% set ip = hostvars[host].ansible_host %}
{% set _ = endpoints.append(ip) %}
{% endfor %}

export ftp_proxy=http://proxy.rvision.local:3128
export http_proxy=http://proxy.rvision.local:3128
export https_proxy=http://proxy.rvision.local:3128
export RSYNC_PROXY=proxy.rvision.local:3128
export no_proxy=localhost,127.0.0.1,.rvision.local,.rvision.pro,.dev.local,.lab150000.local,.lab2003.local,.lab2012.local,.rvision.pro,.rvision.ru,.rvlab.local,.test,{{ endpoints | join(',') }}
export PYTHONWARNINGS="ignore"
