{% if rsyslog_use_json %}
# JSON template

template(name="json-template" type="list") {
  constant(value="{")
  constant(value="\"host\":\"") property(name="hostname") constant(value="\",")
  constant(value="\"service\":\"") property(name="programname") constant(value="\",")
  constant(value="\"msg\":\"") property(name="msg") constant(value="\"}")
}

*.* action(
  type="omfwd"
  target="{{ rsyslog_remote_host }}"
  port="{{ rsyslog_remote_port }}"
  protocol="{{ rsyslog_protocol }}"
  template="json-template"
)

{% else %}
# Classic syslog forwarding

*.* action(
  type="omfwd"
  target="{{ rsyslog_remote_host }}"
  port="{{ rsyslog_remote_port }}"
  protocol="{{ rsyslog_protocol }}"
  template="{{ rsyslog_template }}"
)

{% endif %}
